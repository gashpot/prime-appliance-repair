---
interface Props {
  title: string;
  description?: string;
  image?: string;
}

const {
  title,
  description = "Professional appliance repair services in Troutdale, OR and surrounding areas. Fast, reliable, and affordable.",
  image = "https://primerepair.net/logo.png",
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImage = new URL(image, Astro.site);

// Build breadcrumb crumbs from pathname
const pathParts = Astro.url.pathname.split('/').filter(Boolean);
const breadcrumbs = [{ label: 'Home', href: '/' }];
let currentHref = '';
for (const part of pathParts) {
  currentHref += `/${part}`;
  let label = part.replace(/-/g, ' ');
  // Capitalize each word
  label = label.replace(/\b\w/g, c => c.toUpperCase());
  if (part === 'service-areas') label = 'Service Areas';
  if (part === 'appliance') label = 'Appliance Repair';
  breadcrumbs.push({ label, href: currentHref });
}

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "LocalBusiness",
      "@id": "https://primerepair.net/#business",
      name: "Prime Appliance Repair LLC",
      description: description,
      url: "https://primerepair.net",
      telephone: "+1-503-389-3142",
      email: "contact@primerepair.net",
      address: {
        "@type": "PostalAddress",
        addressRegion: "OR",
        addressCountry: "US",
      },
      geo: {
        "@type": "GeoCoordinates",
        latitude: 45.5373,
        longitude: -122.3873,
      },
      openingHoursSpecification: [
        {
          "@type": "OpeningHoursSpecification",
          dayOfWeek: ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday", "Sunday"],
          opens: "10:00",
          closes: "18:00",
        },
      ],
      priceRange: "$$",
      image: "https://primerepair.net/logo.png",
      areaServed: {
        "@type": "Place",
        name: "Portland Metropolitan Area",
      },
      hasOfferCatalog: {
        "@type": "OfferCatalog",
        name: "Appliance Repair Services",
        itemListElement: [
          {
            "@type": "Offer",
            itemOffered: {
              "@type": "Service",
              name: "Refrigerator & Freezer Repair",
              provider: { "@id": "https://primerepair.net/#business" },
            },
          },
          {
            "@type": "Offer",
            itemOffered: {
              "@type": "Service",
              name: "Washer & Dryer Repair",
              provider: { "@id": "https://primerepair.net/#business" },
            },
          },
          {
            "@type": "Offer",
            itemOffered: {
              "@type": "Service",
              name: "Dishwasher Repair",
              provider: { "@id": "https://primerepair.net/#business" },
            },
          },
          {
            "@type": "Offer",
            itemOffered: {
              "@type": "Service",
              name: "Oven & Range Repair",
              provider: { "@id": "https://primerepair.net/#business" },
            },
          },
        ],
      },
    },
    {
      "@type": "WebSite",
      "@id": "https://primerepair.net/#website",
      url: "https://primerepair.net",
      name: "Prime Appliance Repair LLC",
      publisher: { "@id": "https://primerepair.net/#business" },
    },
    {
      "@type": "BreadcrumbList",
      description: "Breadcrumb navigation",
      itemListElement: breadcrumbs.map((crumb, index) => ({
        "@type": "ListItem",
        position: index + 1,
        name: crumb.label,
        item: new URL(crumb.href, "https://primerepair.net").href,
      })),
    },
  ],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>

    <!-- Canonical URL -->
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content="Prime Appliance Repair LLC" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <link rel="icon" type="image/png" href="/LOGOsmall.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  </head>
  <body>
    <header class="header">
      <nav class="nav">
        <a href="/" class="logo">
          <img src="/logo-side.png" alt="Prime Appliance Repair Logo" class="logo-img" />
        </a>
        <button class="mobile-menu-btn" aria-label="Toggle menu">
          <span></span>
          <span></span>
          <span></span>
        </button>
        <ul class="nav-links">
          <li><a href="/">Home</a></li>
          <li><a href="/services">Services</a></li>
          <li><a href="/about">About</a></li>
          <li><a href="/contact" class="nav-cta">Contact Us</a></li>
        </ul>
      </nav>
    </header>

    {breadcrumbs.length > 1 && (
      <nav class="breadcrumb-nav" aria-label="Breadcrumb">
        <div class="container">
          <ol class="breadcrumb-list" itemscope itemtype="https://schema.org/BreadcrumbList">
            {breadcrumbs.map((crumb, index) => (
              <li
                itemprop="itemListElement"
                itemtype="https://schema.org/ListItem"
                class={index === breadcrumbs.length - 1 ? 'breadcrumb-item active' : 'breadcrumb-item'}
              >
                {index === breadcrumbs.length - 1 ? (
                  <span itemprop="name">{crumb.label}</span>
                ) : (
                  <a itemprop="item" href={crumb.href}>
                    <span itemprop="name">{crumb.label}</span>
                  </a>
                )}
                <meta itemprop="position" content={String(index + 1)} />
                {index < breadcrumbs.length - 1 && <span class="breadcrumb-sep" aria-hidden="true">›</span>}
              </li>
            ))}
          </ol>
        </div>
      </nav>
    )}

    <main>
      <slot />
    </main>

    <footer class="footer">
      <div class="footer-content">
        <div class="footer-brand">
          <img src="/logo.png" alt="Prime Appliance Repair Logo" class="footer-logo" />
          <p>Professional appliance repair you can trust. Serving Troutdale, OR and surrounding East Metro Portland areas.</p>
        </div>
        <div class="footer-links">
          <h4>Quick Links</h4>
          <ul>
            <li><a href="/">Home</a></li>
            <li><a href="/services">Services</a></li>
            <li><a href="/about">About Us</a></li>
            <li><a href="/contact">Contact</a></li>
          </ul>
        </div>
        <div class="footer-links">
          <h4>Service Area</h4>
          <ul>
            <li><a href="/service-areas/portland">Portland</a></li>
            <li><a href="/service-areas/troutdale">Troutdale</a></li>
            <li><a href="/service-areas/gresham">Gresham</a></li>
            <li><a href="/service-areas/fairview">Fairview</a></li>
            <li><a href="/service-areas/happy-valley">Happy Valley</a></li>
          </ul>
        </div>
        <div class="footer-contact">
          <h4>Contact Us</h4>
          <p>📞 <a href="tel:+150****3142">(503) 389-3142</a></p>
          <p>✉️ <a href="mailto:contact@primerepair.net">contact@primerepair.net</a></p>
        </div>
      </div>
      <div class="footer-bottom">
        <p>&copy; 2026 Prime Appliance Repair LLC. All rights reserved.</p>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  :root {
    --primary: #1e40af;
    --primary-light: #3b82f6;
    --accent: #f59e0b;
    --accent-dark: #d97706;
    --dark: #1e293b;
    --gray-700: #334155;
    --gray-500: #64748b;
    --gray-300: #cbd5e1;
    --gray-100: #f1f5f9;
    --white: #ffffff;
    --max-width: 1200px;
    --radius: 8px;
    --shadow: 0 4px 6px -1px rgb(0 0 0 / 0.1);
  }

  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
    color: var(--dark);
    line-height: 1.6;
    background: var(--white);
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  img {
    max-width: 100%;
    height: auto;
  }

  ul {
    list-style: none;
  }

  .container {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  /* Header */
  .header {
    background: var(--white);
    box-shadow: var(--shadow);
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .nav {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 1rem 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .logo-img {
    height: 70px;
    width: auto;
  }

  .footer-logo {
    height: 60px;
    width: auto;
    margin-bottom: 0.5rem;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  .nav-links a {
    font-weight: 500;
    color: var(--gray-700);
    transition: color 0.2s;
  }

  .nav-links a:hover {
    color: var(--primary);
  }

  .nav-cta {
    background: var(--primary);
    color: var(--white) !important;
    padding: 0.625rem 1.25rem;
    border-radius: var(--radius);
    font-weight: 600;
    transition: background 0.2s;
  }

  .nav-cta:hover {
    background: var(--primary-light);
  }

  .mobile-menu-btn {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 5px;
  }

  .mobile-menu-btn span {
    display: block;
    width: 24px;
    height: 2px;
    background: var(--dark);
    border-radius: 2px;
  }

  /* Footer */
  .footer {
    background: var(--dark);
    color: var(--gray-300);
    padding: 4rem 0 0;
  }

  .footer-content {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 1.5rem;
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1.5fr;
    gap: 3rem;
  }

  .footer-brand .logo {
    color: var(--white);
    margin-bottom: 1rem;
  }

  .footer-brand p {
    color: var(--gray-500);
    font-size: 0.9rem;
    margin-top: 0.5rem;
  }

  .footer-brand {
    text-align: center;
  }

  .footer-brand img.footer-logo {
    display: block;
    margin: 0 auto;
  }

  .footer-links h4,
  .footer-contact h4 {
    color: var(--white);
    font-size: 1rem;
    margin-bottom: 1rem;
  }

  .footer-links ul {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .footer-links a {
    color: var(--gray-500);
    font-size: 0.9rem;
    transition: color 0.2s;
  }

  .footer-links a:hover {
    color: var(--white);
  }

  .footer-contact p {
    color: var(--gray-500);
    font-size: 0.9rem;
    margin-bottom: 0.5rem;
  }

  .footer-contact a {
    color: var(--gray-300);
    transition: color 0.2s;
  }

  .footer-contact a:hover {
    color: var(--accent);
  }

  .footer-bottom {
    border-top: 1px solid var(--gray-700);
    margin-top: 3rem;
    padding: 1.5rem;
    text-align: center;
    color: var(--gray-500);
    font-size: 0.875rem;
  }

  /* Breadcrumbs */
  .breadcrumb-nav {
    background: var(--gray-100);
    border-bottom: 1px solid var(--gray-300);
    padding: 0.75rem 0;
  }

  .breadcrumb-list {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .breadcrumb-item {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    font-size: 0.875rem;
  }

  .breadcrumb-item a {
    color: var(--primary);
    text-decoration: none;
    transition: color 0.15s;
  }

  .breadcrumb-item a:hover {
    color: var(--accent-dark);
    text-decoration: underline;
  }

  .breadcrumb-item.active span {
    color: var(--gray-500);
    font-weight: 500;
  }

  .breadcrumb-sep {
    color: var(--gray-400);
    font-size: 0.875rem;
    margin: 0 0.15rem;
  }

  @media (max-width: 900px) {
    .footer-content {
      grid-template-columns: 1fr 1fr;
      gap: 2rem;
    }
  }

  @media (max-width: 640px) {
    .mobile-menu-btn {
      display: flex;
      position: absolute;
      left: 1.5rem;
      top: 50%;
      transform: translateY(-50%);
      z-index: 10;
    }

    .nav {
      justify-content: center;
      position: relative;
    }

    .logo-img {
      content: url("/logo.png");
    }

    .logo {
      position: relative;
      z-index: 10;
    }

    .nav-links {
      display: none;
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      background: var(--white);
      flex-direction: column;
      padding: 1.5rem;
      gap: 1rem;
      box-shadow: var(--shadow);
    }

    .nav-links.active {
      display: flex;
    }

    .footer-content {
      grid-template-columns: 1fr;
      text-align: center;
    }

    .footer-brand {
      text-align: center;
    }

    .footer-brand .logo {
      justify-content: center;
    }
  }
</style>

<script>
  const menuBtn = document.querySelector('.mobile-menu-btn');
  const navLinks = document.querySelector('.nav-links');

  menuBtn?.addEventListener('click', () => {
    navLinks?.classList.toggle('active');
  });
</script>
