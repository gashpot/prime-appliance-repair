---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact Us | Prime Appliance Repair" description="Contact Prime Appliance Repair LLC for appliance repair service in Troutdale, OR and surrounding areas.">

  <!-- Page Header -->
  <section class="page-header">
    <div class="container">
      <h1>Contact Us</h1>
      <p>Ready to get your appliance fixed? Reach out and we'll get back to you within the hour during business hours.</p>
    </div>
  </section>

  <!-- Contact Section -->
  <section class="contact-section">
    <div class="container">
      <div class="contact-grid">

        <!-- Contact Form -->
        <div class="contact-form-wrapper">
          <h2>Send Us a Message</h2>
          <p>Fill out the form below and we'll get back to you shortly.</p>

          <form id="contact-form" method="POST" action="/api/contact">

            <div class="form-row">
              <div class="form-group">
                <label for="name">Your Name *</label>
                <input type="text" id="name" name="name" required placeholder="John Smith" />
              </div>
              <div class="form-group">
                <label for="phone">Phone Number *</label>
                <input type="tel" id="phone" name="phone" required placeholder="(503) 389-3142" />
              </div>
            </div>

            <div class="form-row">
              <div class="form-group">
                <label for="email">Email Address</label>
                <input type="email" id="email" name="email" placeholder="john@example.com" />
              </div>
              <div class="form-group">
                <label for="city">City *</label>
                <input type="text" id="city" name="city" required placeholder="Troutdale" />
              </div>
            </div>

            <div class="form-group">
              <label for="appliance">Appliance Type *</label>
              <select id="appliance" name="appliance" required>
                <option value="" disabled selected>Select an appliance</option>
                <option value="refrigerator">Refrigerator</option>
                <option value="washer">Washer</option>
                <option value="dryer">Dryer</option>
                <option value="dishwasher">Dishwasher</option>
                <option value="oven">Oven / Range</option>
                <option value="microwave">Microwave</option>
                <option value="ice-machine">Ice Machine</option>
                <option value="commercial">Commercial Appliance</option>
                <option value="other">Other</option>
              </select>
            </div>

            <div class="form-group">
              <label for="brand">Brand / Manufacturer</label>
              <input type="text" id="brand" name="brand" placeholder="Whirlpool, GE, Samsung, LG..." />
            </div>

            <div class="form-group">
              <label for="issue">Describe the Problem *</label>
              <textarea id="issue" name="issue" required rows="5" placeholder="Please describe what's wrong with your appliance — symptoms, when it started, any error codes..."></textarea>
            </div>

            <div class="form-group">
              <label for="preferred-time">Preferred Contact Time</label>
              <select id="preferred-time" name="preferred-time">
                <option value="morning">Morning (10am - 1pm)</option>
                <option value="afternoon">Afternoon (1pm - 6pm)</option>
                <option value="anytime">Anytime (10am - 6pm)</option>
              </select>
            </div>

            <button type="submit" class="btn btn-primary btn-full">Send Message</button>
          </form>
        </div>

        <!-- Contact Info -->
        <div class="contact-info">
          <div class="info-card">
            <h3>Get In Touch</h3>
            <div class="info-item">
              <div class="info-icon">📞</div>
              <div>
                <h4>Phone</h4>
                <p><a href="tel:+15033893142">(503) 389-3142</a></p>
              </div>
            </div>
            <div class="info-item">
              <div class="info-icon">✉️</div>
              <div>
                <h4>Email</h4>
                <p><a href="mailto:contact@primerepair.net">contact@primerepair.net</a></p>
              </div>
            </div>
            <div class="info-item">
              <div class="info-icon">📍</div>
              <div>
                <h4>Service Area</h4>
                <p>Troutdale, Portland, Gresham,<br>Fairview, and surrounding areas</p>
              </div>
            </div>
            <div class="info-item">
              <div class="info-icon">🕐</div>
              <div>
                <h4>Hours</h4>
                <p>Mon - Sun: 10am - 6pm</p>
              </div>
            </div>
          </div>

          <div class="info-card response-card">
            <h3>Quick Response</h3>
            <p>We typically respond to inquiries within:</p>
            <div class="response-time">
              <span class="time-badge">~30 min</span>
              <span>during business hours</span>
            </div>
            <p class="response-note">For urgent repairs, call us directly — you'll get through faster.</p>
          </div>

          <div class="info-card">
            <h3>What to Expect</h3>
            <ol class="expect-list">
              <li>
                <span class="step-num">1</span>
                <div>
                  <strong>Contact us</strong>
                  <p>Call or fill out the form with your appliance issue.</p>
                </div>
              </li>
              <li>
                <span class="step-num">2</span>
                <div>
                  <strong>We call you back</strong>
                  <p>We discuss the problem and schedule a visit.</p>
                </div>
              </li>
              <li>
                <span class="step-num">3</span>
                <div>
                  <strong>We diagnose</strong>
                  <p>On-site diagnosis with an upfront quote.</p>
                </div>
              </li>
              <li>
                <span class="step-num">4</span>
                <div>
                  <strong>You approve</strong>
                  <p>We fix it only when you say go.</p>
                </div>
              </li>
            </ol>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- Map Area -->
  <section class="map-section">
    <div class="container">
      <h2>Service Area</h2>
      <p class="map-subtitle">We service Troutdale and the greater East Metro Portland area. Service calls outside this area may incur a travel fee — call to confirm.</p>
      <div class="map-placeholder">
        <div class="map-inner">
          <span class="map-icon">📍</span>
          <p><strong>Troutdale, OR</strong></p>
          <p class="map-cities">Also serving: Portland, Gresham, Fairview, Wood Village, Camas, Washougal, Happy Valley, Damascus, Clackamas</p>
        </div>
      </div>
    </div>
  </section>

</Layout>

<style>
  .page-header {
    background: var(--primary);
    color: var(--white);
    padding: 4rem 0;
    text-align: center;
  }

  .page-header h1 {
    font-size: 2.75rem;
    font-weight: 800;
    margin-bottom: 0.75rem;
  }

  .page-header p {
    font-size: 1.15rem;
    color: #bfdbfe;
    max-width: 600px;
    margin: 0 auto;
  }

  .contact-section {
    padding: 5rem 0;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: 4rem;
  }

  .contact-form-wrapper h2 {
    font-size: 1.75rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
  }

  .contact-form-wrapper > p {
    color: var(--gray-500);
    margin-bottom: 2rem;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .form-group {
    margin-bottom: 1.25rem;
  }

  .form-group label {
    display: block;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--dark);
    margin-bottom: 0.4rem;
  }

  .form-group input,
  .form-group select,
  .form-group textarea {
    width: 100%;
    padding: 0.75rem 1rem;
    border: 2px solid var(--gray-300);
    border-radius: var(--radius);
    font-size: 1rem;
    font-family: inherit;
    transition: border-color 0.2s;
    background: var(--white);
  }

  .form-group input:focus,
  .form-group select:focus,
  .form-group textarea:focus {
    outline: none;
    border-color: var(--primary);
  }

  .form-group input::placeholder,
  .form-group textarea::placeholder {
    color: var(--gray-500);
  }

  .form-group textarea {
    resize: vertical;
    min-height: 120px;
  }

  .btn {
    display: inline-block;
    padding: 0.875rem 1.75rem;
    border-radius: var(--radius);
    font-weight: 600;
    font-size: 1rem;
    transition: all 0.2s;
    cursor: pointer;
    border: none;
  }

  .btn-primary {
    background: var(--primary);
    color: var(--white);
  }

  .btn-primary:hover {
    background: var(--primary-light);
  }

  .btn-full {
    width: 100%;
    font-size: 1.05rem;
  }

  /* Info Cards */
  .contact-info {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .info-card {
    background: var(--gray-100);
    padding: 1.75rem;
    border-radius: 12px;
  }

  .info-card h3 {
    font-size: 1.15rem;
    font-weight: 600;
    margin-bottom: 1.25rem;
  }

  .info-item {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
    margin-bottom: 1.25rem;
  }

  .info-item:last-child {
    margin-bottom: 0;
  }

  .info-icon {
    font-size: 1.5rem;
    flex-shrink: 0;
  }

  .info-item h4 {
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--gray-500);
    margin-bottom: 0.2rem;
  }

  .info-item p {
    font-size: 0.95rem;
    color: var(--dark);
  }

  .info-item a {
    color: var(--primary);
    font-weight: 500;
  }

  .info-item a:hover {
    text-decoration: underline;
  }

  /* Response Card */
  .response-card {
    background: var(--dark);
    color: var(--white);
  }

  .response-card h3 {
    color: var(--white);
  }

  .response-card p {
    color: var(--gray-300);
    font-size: 0.9rem;
    margin-bottom: 1rem;
  }

  .response-time {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1rem;
  }

  .time-badge {
    background: var(--accent);
    color: var(--dark);
    font-weight: 700;
    font-size: 1.1rem;
    padding: 0.25rem 0.75rem;
    border-radius: 6px;
  }

  .response-note {
    color: var(--gray-500) !important;
    font-size: 0.8rem !important;
  }

  /* Expect List */
  .expect-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .expect-list li {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
  }

  .step-num {
    width: 28px;
    height: 28px;
    background: var(--primary);
    color: var(--white);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.85rem;
    font-weight: 700;
    flex-shrink: 0;
  }

  .expect-list strong {
    font-size: 0.95rem;
    display: block;
    margin-bottom: 0.15rem;
  }

  .expect-list p {
    color: var(--gray-500);
    font-size: 0.85rem;
  }

  /* Map */
  .map-section {
    background: var(--gray-100);
    padding: 5rem 0;
  }

  .map-section h2 {
    text-align: center;
    font-size: 2rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
  }

  .map-subtitle {
    text-align: center;
    color: var(--gray-500);
    max-width: 600px;
    margin: 0 auto 2.5rem;
  }

  .map-placeholder {
    background: var(--white);
    border-radius: 12px;
    padding: 3rem;
    text-align: center;
    box-shadow: 0 4px 16px rgba(0,0,0,0.06);
  }

  .map-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
  }

  .map-icon {
    font-size: 3rem;
  }

  .map-inner p {
    font-size: 1.1rem;
  }

  .map-cities {
    color: var(--gray-500);
    font-size: 0.9rem !important;
    max-width: 500px;
  }

  @media (max-width: 900px) {
    .contact-grid {
      grid-template-columns: 1fr;
    }

    .form-row {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .page-header h1 {
      font-size: 2rem;
    }

    .map-placeholder {
      padding: 2rem;
    }
  }
</style>
