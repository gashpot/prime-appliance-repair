---
import Layout from '../../layouts/Layout.astro';

const city = "Gresham";
const cityLower = "gresham";
const state = "OR";
const serviceArea = "Gresham, Oregon";
const intro = "When your appliance breaks down in Gresham, you need someone who knows the area — not a big corporate call center. Prime Appliance Repair has been serving Gresham and the broader East Metro Portland area for years, and we treat every customer like a neighbor.";
const responseTime = "same-day";
---

<Layout
  title={`${city} Appliance Repair | ${city}, ${state} | Prime Appliance Repair`}
  description={`Professional appliance repair in ${city}, ${state}. Fast ${responseTime} service for refrigerators, washers, dryers, dishwashers, ovens, and more. Call ${city} (503) 389-3142.`}
>
  <!-- LocalBusiness JSON-LD for this service area -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "@id": `https://primerepair.net/#area-${cityLower}`,
    name: `Prime Appliance Repair LLC - ${city}`,
    description: `Appliance repair services serving ${city} and surrounding East Metro Portland areas.`,
    url: `https://primerepair.net/service-areas/${cityLower}`,
    telephone: "+1-503-389-3142",
    areaServed: {
      "@type": "City",
      name: city,
      addressRegion: state,
      addressCountry: "US"
    },
    parentOrganization: { "@id": "https://primerepair.net/#business" }
  })} />

  <!-- Page Header -->
  <section class="page-header">
    <div class="container">
      <div class="area-badge">Service Area</div>
      <h1>{city} Appliance Repair</h1>
      <p>Fast, reliable repairs you can count on. Proudly serving {city} and the surrounding East Metro Portland area.</p>
    </div>
  </section>

  <!-- Intro -->
  <section class="intro-section">
    <div class="container">
      <div class="intro-grid">
        <div class="intro-content">
          <h2>Your Local {city} Appliance Repair Team</h2>
          <p>{intro}</p>
          <p>We know Gresham homes — from the newer developments around Division Street to the established neighborhoods near Gresham Butte. No matter what brand or model you have, we've probably seen it before. Our truck is stocked with common parts, so we can often complete repairs in a single visit.</p>
          <div class="quick-facts">
            <div class="fact-item">
              <span class="fact-icon">📍</span>
              <div>
                <strong>Serving {city}</strong>
                <span>And all nearby East Metro Portland communities</span>
              </div>
            </div>
            <div class="fact-item">
              <span class="fact-icon">⚡</span>
              <div>
                <strong>{responseTime.charAt(0).toUpperCase() + responseTime.slice(1)} Response</strong>
                <span>Call by 2pm and we often arrive today</span>
              </div>
            </div>
            <div class="fact-item">
              <span class="fact-icon">🛡️</span>
              <div>
                <strong>30-Day Warranty</strong>
                <span>On all parts and labor — peace of mind guaranteed</span>
              </div>
            </div>
          </div>
        </div>
        <div class="intro-cta">
          <div class="cta-card">
            <div class="cta-card-header">
              <h3>Request a Repair</h3>
              <p>We come to you in {city}. Diagnostic fee applies.</p>
            </div>
            <a href="tel:+15033893142" class="btn btn-accent btn-full">📞 (503) 389-3142</a>
            <a href="/contact/" class="btn btn-outline btn-full">Book Online</a>
            <div class="cta-note">Same-day or next-day availability</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Services in this area -->
  <section class="area-services-section">
    <div class="container">
      <h2>Appliance Repair in {city}</h2>
      <p class="section-subtitle">We service all major brands and appliance types in the {city} area</p>
      <div class="services-grid">
        <a href="/services#refrigerators" class="service-tile">
          <div class="service-tile-icon">🧊</div>
          <h3>Refrigerator & Freezer</h3>
          <p>Not cooling, ice maker broken, leaking water, strange noises — we fix it all.</p>
        </a>
        <a href="/services#washers" class="service-tile">
          <div class="service-tile-icon">👕</div>
          <h3>Washer Repair</h3>
          <p>Not draining, spinning issues, leaks, or error codes — we get your laundry moving again.</p>
        </a>
        <a href="/services#dryers" class="service-tile">
          <div class="service-tile-icon">🔥</div>
          <h3>Dryer Repair</h3>
          <p>Not heating, taking too long, squeaking, or overheating — gas and electric.</p>
        </a>
        <a href="/services#dishwashers" class="service-tile">
          <div class="service-tile-icon">🍽️</div>
          <h3>Dishwasher Repair</h3>
          <p>Drainage problems, leaks, not cleaning, pump or spray arm issues.</p>
        </a>
        <a href="/services#ovens" class="service-tile">
          <div class="service-tile-icon">🍳</div>
          <h3>Oven & Range</h3>
          <p>Gas and electric — temperature issues, igniter problems, burners not lighting.</p>
        </a>
        <a href="/services#microwaves" class="service-tile">
          <div class="service-tile-icon">📻</div>
          <h3>Microwave Repair</h3>
          <p>Not heating, turntable issues, sparking, control panel problems.</p>
        </a>
      </div>
      <div class="services-link">
        <a href="/services/" class="btn btn-primary">View All Services</a>
      </div>
    </div>
  </section>

  <!-- Why Local -->
  <section class="why-local-section">
    <div class="container">
      <h2>Why Gresham Residents Choose Us</h2>
      <div class="why-grid">
        <div class="why-card">
          <span class="why-icon">🚛</span>
          <h3>Fully Equipped Truck</h3>
          <p>We arrive with the parts needed for common repairs — no waiting on parts to come in.</p>
        </div>
        <div class="why-card">
          <span class="why-icon">💰</span>
          <h3>Upfront Pricing</h3>
          <p>We quote before we start. No surprises, no add-on fees after the work is done.</p>
        </div>
        <div class="why-card">
          <span class="why-icon">👨‍🔧</span>
          <h3>One Person, Every Job</h3>
          <p>Anton handles every repair personally. You deal directly with the technician, every time.</p>
        </div>
        <div class="why-card">
          <span class="why-icon">⭐</span>
          <h3>30-Day Warranty</h3>
          <p>If something we fixed breaks again within 30 days, we come back and fix it free.</p>
        </div>
        <div class="why-card">
          <span class="why-icon">📅</span>
          <h3>Flexible Scheduling</h3>
          <p>Same-day and next-day appointments available. We text when we're on the way.</p>
        </div>
        <div class="why-card">
          <span class="why-icon">🏠</span>
          <h3>Respect for Your Home</h3>
          <p>Shoe covers worn inside, work area cleaned when we're done. We leave it like we found it.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Areas Nearby -->
  <section class="nearby-section">
    <div class="container">
      <div class="nearby-box">
        <h2>Also Serving East Metro Portland</h2>
        <p>In addition to {city}, we serve the surrounding communities:</p>
        <div class="nearby-list">
          <span class="nearby-item">Troutdale</span>
          <span class="nearby-item">Happy Valley</span>
          <span class="nearby-item">Fairview</span>
          <span class="nearby-item">Camas</span>
          <span class="nearby-item">Washougal</span>
          <span class="nearby-item">Portland (East)</span>
          <span class="nearby-item">Gresham</span>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-section">
    <div class="container">
      <div class="cta-box">
        <h2>Appliance Broke in {city}?</h2>
        <p>Call now or book online. We typically have availability today or tomorrow.</p>
        <div class="cta-btns">
          <a href="tel:+15033893142" class="btn btn-accent">📞 (503) 389-3142</a>
          <a href="/contact/" class="btn btn-outline-white">Get a Quote</a>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .page-header {
    background: var(--primary);
    color: var(--white);
    padding: 4rem 0;
    text-align: center;
  }

  .page-header h1 {
    font-size: 2.75rem;
    font-weight: 800;
    margin-bottom: 0.75rem;
  }

  .page-header p {
    font-size: 1.15rem;
    color: #bfdbfe;
    max-width: 600px;
    margin: 0 auto;
  }

  .area-badge {
    display: inline-block;
    background: var(--accent);
    color: var(--dark);
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 0.3rem 0.9rem;
    border-radius: 999px;
    margin-bottom: 1rem;
  }

  /* Intro */
  .intro-section {
    padding: 5rem 0;
  }

  .intro-grid {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 4rem;
    align-items: start;
  }

  .intro-content h2 {
    font-size: 2.25rem;
    font-weight: 700;
    margin-bottom: 1.25rem;
    text-align: center;
  }

  .intro-content > p {
    color: var(--gray-500);
    font-size: 1.05rem;
    line-height: 1.8;
    margin-bottom: 1rem;
    text-align: center;
  }

  .quick-facts {
    margin-top: 2rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .fact-item {
    display: flex;
    align-items: center;
    gap: 1rem;
    background: var(--gray-100);
    padding: 1rem 1.25rem;
    border-radius: 10px;
  }

  .fact-icon {
    font-size: 1.5rem;
    flex-shrink: 0;
  }

  .fact-item div {
    display: flex;
    flex-direction: column;
  }

  .fact-item strong {
    font-size: 1rem;
    font-weight: 600;
    color: var(--dark);
  }

  .fact-item span {
    font-size: 0.875rem;
    color: var(--gray-500);
  }

  /* CTA Card */
  .intro-cta {
    position: sticky;
    top: 2rem;
  }

  .cta-card {
    background: var(--dark);
    color: var(--white);
    border-radius: 16px;
    padding: 2rem;
    text-align: center;
  }

  .cta-card-header {
    margin-bottom: 1.5rem;
  }

  .cta-card-header h3 {
    font-size: 1.5rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
  }

  .cta-card-header p {
    color: #9ca3af;
    font-size: 0.9rem;
  }

  .btn-full {
    display: block;
    width: 100%;
    text-align: center;
    margin-bottom: 0.75rem;
  }

  .btn-accent {
    background: var(--accent);
    color: var(--dark);
    padding: 0.875rem 1.5rem;
    border-radius: var(--radius);
    font-weight: 600;
    font-size: 1rem;
    transition: all 0.2s;
    text-decoration: none;
    display: inline-block;
  }

  .btn-accent:hover {
    background: var(--accent-dark);
  }

  .btn-outline {
    background: transparent;
    color: var(--white);
    border: 2px solid rgba(255,255,255,0.3);
    padding: 0.875rem 1.5rem;
    border-radius: var(--radius);
    font-weight: 600;
    font-size: 1rem;
    transition: all 0.2s;
    text-decoration: none;
    display: inline-block;
  }

  .btn-outline:hover {
    background: rgba(255,255,255,0.1);
    border-color: rgba(255,255,255,0.6);
  }

  .cta-note {
    margin-top: 1rem;
    font-size: 0.8rem;
    color: #6b7280;
  }

  /* Area Services */
  .area-services-section {
    background: var(--gray-100);
    padding: 5rem 0;
    text-align: center;
  }

  .area-services-section h2 {
    font-size: 2.25rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
  }

  .section-subtitle {
    color: var(--gray-500);
    margin-bottom: 3rem;
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .service-tile {
    background: var(--white);
    padding: 2rem;
    border-radius: 12px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.05);
    text-decoration: none;
    color: inherit;
    text-align: center;
    transition: all 0.2s;
  }

  .service-tile:hover {
    box-shadow: 0 8px 24px rgba(0,0,0,0.1);
    transform: translateY(-2px);
  }

  .service-tile-icon {
    font-size: 2.5rem;
    margin-bottom: 1rem;
  }

  .service-tile h3 {
    font-size: 1.2rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
  }

  .service-tile p {
    color: var(--gray-500);
    font-size: 0.9rem;
    line-height: 1.5;
  }

  .services-link {
    margin-top: 2.5rem;
  }

  .btn-primary {
    background: var(--primary);
    color: var(--white);
    padding: 0.875rem 1.75rem;
    border-radius: var(--radius);
    font-weight: 600;
    font-size: 1rem;
    transition: all 0.2s;
    text-decoration: none;
    display: inline-block;
  }

  .btn-primary:hover {
    background: var(--primary-light);
  }

  /* Why Local */
  .why-local-section {
    padding: 5rem 0;
  }

  .why-local-section h2 {
    text-align: center;
    font-size: 2.25rem;
    font-weight: 700;
    margin-bottom: 3rem;
  }

  .why-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .why-card {
    background: var(--gray-100);
    padding: 2rem;
    border-radius: 12px;
    text-align: center;
  }

  .why-icon {
    font-size: 2rem;
    margin-bottom: 1rem;
    display: block;
  }

  .why-card h3 {
    font-size: 1.1rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
  }

  .why-card p {
    color: var(--gray-500);
    font-size: 0.9rem;
    line-height: 1.5;
  }

  /* Nearby */
  .nearby-section {
    padding: 0 0 5rem;
  }

  .nearby-box {
    background: var(--gray-100);
    border-radius: 16px;
    padding: 3rem;
    text-align: center;
  }

  .nearby-box h2 {
    font-size: 1.75rem;
    font-weight: 700;
    margin-bottom: 0.75rem;
  }

  .nearby-box > p {
    color: var(--gray-500);
    margin-bottom: 1.5rem;
  }

  .nearby-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    justify-content: center;
  }

  .nearby-item {
    background: var(--white);
    border: 1px solid var(--gray-300);
    padding: 0.5rem 1rem;
    border-radius: 999px;
    font-size: 0.9rem;
    color: var(--gray-700);
  }

  /* CTA */
  .cta-section {
    padding: 0 0 5rem;
  }

  .cta-box {
    background: var(--dark);
    color: var(--white);
    text-align: center;
    padding: 4rem;
    border-radius: 16px;
  }

  .cta-box h2 {
    font-size: 2.25rem;
    font-weight: 700;
    margin-bottom: 1rem;
  }

  .cta-box p {
    color: #d1d5db;
    font-size: 1.1rem;
    margin-bottom: 2rem;
  }

  .cta-btns {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .btn-outline-white {
    background: transparent;
    color: var(--white);
    border: 2px solid var(--white);
    padding: 0.875rem 1.75rem;
    border-radius: var(--radius);
    font-weight: 600;
    font-size: 1rem;
    transition: all 0.2s;
    text-decoration: none;
    display: inline-block;
  }

  .btn-outline-white:hover {
    background: var(--white);
    color: var(--dark);
  }

  /* Responsive */
  @media (max-width: 900px) {
    .intro-grid {
      grid-template-columns: 1fr;
    }

    .intro-cta {
      position: static;
    }

    .services-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .why-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .page-header h1 {
      font-size: 2rem;
    }

    .services-grid {
      grid-template-columns: 1fr;
    }

    .why-grid {
      grid-template-columns: 1fr;
    }

    .cta-btns {
      flex-direction: column;
      align-items: center;
    }

    .cta-box {
      padding: 2.5rem;
    }
  }
</style>
