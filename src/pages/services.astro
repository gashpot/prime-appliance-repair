---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Services | Prime Appliance Repair" description="Professional appliance repair services in Troutdale, OR. Refrigerators, washers, dryers, dishwashers, ovens, and more.">

  <!-- Page Header -->
  <section class="page-header">
    <div class="container">
      <h1>Our Services</h1>
      <p>Professional repair for all major household appliances. No job too big or too small.</p>
    </div>
  </section>

  <!-- Services List -->
  <section class="services-list">
    <div class="container">

      <!-- Refrigerators & Freezers -->
      <div class="service-row" id="refrigerators">
        <div class="service-row-image">
          <img src="/images/services/refrigerator.jpg" alt="Refrigerator and freezer repair service" loading="lazy" />
        </div>
        <div class="service-row-content">
          <div class="service-badge">Most Common</div>
          <h2>Refrigerator & Freezer Repair</h2>
          <p>Refrigerators and freezers are the hardest-working appliances in your home. When they break down — whether it's not cooling, making strange noises, or leaking water — it becomes an emergency fast. We repair all brands and models, side-by-side, French door, top freezer, chest freezers, and compact units.</p>
          <div class="service-details">
            <div class="detail-group">
              <h4>Common Repairs</h4>
              <ul>
                <li>Not cooling or freezing</li>
                <li>Ice maker not working</li>
                <li>Strange noises or vibrations</li>
                <li>Water leaks</li>
                <li>Door seal replacement</li>
                <li>Thermostat and temperature control</li>
                <li>Frost buildup</li>
                <li>Compressor problems</li>
              </ul>
            </div>
            <div class="detail-group">
              <h4>Brands Serviced</h4>
              <ul>
                <li>Whirlpool, GE, Samsung, LG</li>
                <li>Frigidaire, Maytag, Kenmore</li>
                <li>Bosch, Sub-Zero, Wolf</li>
                <li>True, Scotsman, EdgeStar</li>
                <li>And more</li>
              </ul>
            </div>
          </div>
          <a href="/contact" class="btn btn-primary">Schedule Repair</a>
        </div>
      </div>

      <!-- Washers -->
      <div class="service-row" id="washers">
        <div class="service-row-image">
          <img src="/images/services/washer.jpg" alt="Washing machine repair service" loading="lazy" />
        </div>
        <div class="service-row-content">
          <h2>Washer Repair</h2>
          <p>Laundry waits for no one. Whether you have a top-loader, front-loader, or stackable combo, we diagnose and fix washer issues quickly so you're not hand-washing clothes for long. We handle all major brands and models.</p>
          <div class="service-details">
            <div class="detail-group">
              <h4>Common Repairs</h4>
              <ul>
                <li>Not draining or spinning</li>
                <li>Leaking water</li>
                <li>Agitator or drum not working</li>
                <li>Excessive shaking or noise</li>
                <li>Error codes on display</li>
                <li>Door lock issues</li>
              </ul>
            </div>
            <div class="detail-group">
              <h4>Brands Serviced</h4>
              <ul>
                <li>Whirlpool, Maytag, GE</li>
                <li>Samsung, LG, Electrolux</li>
                <li>Speed Queen, Amana</li>
                <li>And more</li>
              </ul>
            </div>
          </div>
          <a href="/contact" class="btn btn-primary">Schedule Repair</a>
        </div>
      </div>

      <!-- Dryers -->
      <div class="service-row" id="dryers">
        <div class="service-row-image">
          <img src="/images/services/dryer.jpg" alt="Dryer repair service" loading="lazy" />
        </div>
        <div class="service-row-content">
          <h2>Dryer Repair</h2>
          <p>A broken dryer is more than an inconvenience — it's a fire hazard if vents aren't working properly. We service both gas and electric dryers, quickly diagnosing heating issues, airflow problems, and mechanical failures.</p>
          <div class="service-details">
            <div class="detail-group">
              <h4>Common Repairs</h4>
              <ul>
                <li>Not heating</li>
                <li>Taking too long to dry</li>
                <li>Making rumbling or squeaking noises</li>
                <li>Overheating or shutting off</li>
                <li>Drum not turning</li>
                <li>Vent and duct cleaning</li>
              </ul>
            </div>
            <div class="detail-group">
              <h4>Brands Serviced</h4>
              <ul>
                <li>Whirlpool, Maytag, GE</li>
                <li>Samsung, LG, Electrolux</li>
                <li>Speed Queen, Amana</li>
                <li>And more</li>
              </ul>
            </div>
          </div>
          <a href="/contact" class="btn btn-primary">Schedule Repair</a>
        </div>
      </div>

      <!-- Dishwashers -->
      <div class="service-row" id="dishwashers">
        <div class="service-row-image">
          <img src="/images/services/dishwasher.jpg" alt="Dishwasher repair service" loading="lazy" />
        </div>
        <div class="service-row-content">
          <h2>Dishwasher Repair</h2>
          <p>Hand-washing dishes is not a long-term solution. We fix all dishwasher issues — from drainage problems and leaks to pumps, spray arms, and control boards. We get your dishwasher cleaning plates again, properly.</p>
          <div class="service-details">
            <div class="detail-group">
              <h4>Common Repairs</h4>
              <ul>
                <li>Not draining or leaving standing water</li>
                <li>Not cleaning dishes properly</li>
                <li>Leaks around the door</li>
                <li>Pump or motor issues</li>
                <li>Spray arm replacement</li>
                <li>Door seal and latch repair</li>
              </ul>
            </div>
            <div class="detail-group">
              <h4>Brands Serviced</h4>
              <ul>
                <li>Bosch, KitchenAid, Whirlpool</li>
                <li>GE, Frigidaire, Maytag</li>
                <li>Samsung, LG, Miele</li>
                <li>And more</li>
              </ul>
            </div>
          </div>
          <a href="/contact" class="btn btn-primary">Schedule Repair</a>
        </div>
      </div>

      <!-- Ovens & Ranges -->
      <div class="service-row" id="ovens">
        <div class="service-row-image">
          <img src="/images/services/oven-range.jpg" alt="Oven and range repair service" loading="lazy" />
        </div>
        <div class="service-row-content">
          <h2>Oven & Range Repair</h2>
          <p>Whether you're feeding a family or just trying to make dinner, a broken oven throws everything off. We service gas and electric ovens, ranges, and cooktops — from simple temperature issues to complex igniter and heating element replacements.</p>
          <div class="service-details">
            <div class="detail-group">
              <h4>Common Repairs</h4>
              <ul>
                <li>Not heating or uneven heating</li>
                <li>Gas igniter problems</li>
                <li>Temperature sensor issues</li>
                <li>Burners not lighting</li>
                <li>Control board and display issues</li>
                <li>Self-cleaning function broken</li>
              </ul>
            </div>
            <div class="detail-group">
              <h4>Brands Serviced</h4>
              <ul>
                <li>Whirlpool, GE, Frigidaire</li>
                <li>Samsung, LG, Bosch</li>
                <li>Viking, Wolf, Thermador</li>
                <li>And more</li>
              </ul>
            </div>
          </div>
          <a href="/contact" class="btn btn-primary">Schedule Repair</a>
        </div>
      </div>

      <!-- Microwaves -->
      <div class="service-row" id="microwaves">
        <div class="service-row-image">
          <img src="/images/services/microwave.jpg" alt="Microwave repair service" loading="lazy" />
        </div>
        <div class="service-row-content">
          <h2>Microwave Repair</h2>
          <p>Microwaves make meal prep fast and convenient. When yours stops heating, runs too long, or has a broken turntable, we get it working again. We repair all types — countertop, over-the-range, and built-in microwaves.</p>
          <div class="service-details">
            <div class="detail-group">
              <h4>Common Repairs</h4>
              <ul>
                <li>Not heating</li>
                <li>Turntable not rotating</li>
                <li>Sparking or arcing</li>
                <li>Display and control panel issues</li>
                <li>Door switch problems</li>
                <li>Strange noises or burning smell</li>
              </ul>
            </div>
            <div class="detail-group">
              <h4>Brands Serviced</h4>
              <ul>
                <li>Whirlpool, GE, Samsung</li>
                <li>LG, Frigidaire, Maytag</li>
                <li>Panasonic, Sharp, Toshiba</li>
                <li>And more</li>
              </ul>
            </div>
          </div>
          <a href="/contact" class="btn btn-primary">Schedule Repair</a>
        </div>
      </div>

      <!-- Commercial -->
      <div class="service-row commercial-row">
        <div class="service-row-image">
          <img src="/images/services/commercial.jpg" alt="Commercial appliance repair" loading="lazy" />
        </div>
        <div class="service-row-content">
          <div class="service-badge commercial-badge">Commercial</div>
          <h2>Commercial Appliance Repair</h2>
          <p>We also service commercial-grade appliances in restaurants, bars, convenience stores, laundromats, and office buildings. If your business depends on an appliance, we understand the urgency.</p>
          <div class="service-details">
            <div class="detail-group">
              <h4>Equipment We Service</h4>
              <ul>
                <li>Commercial refrigerators and freezers</li>
                <li>Ice machines (Manitowoc, Hoshizaki)</li>
                <li>Commercial dishwashers</li>
                <li>Reach-in coolers and display cases</li>
                <li>Under-counter refrigerators</li>
              </ul>
            </div>
            <div class="detail-group">
              <h4>Service Options</h4>
              <ul>
                <li>Preventive maintenance plans</li>
                <li>Emergency after-hours service</li>
                <li>Service contracts available</li>
                <li>Same-day response for commercial accounts</li>
              </ul>
            </div>
          </div>
          <a href="/contact" class="btn btn-primary">Contact for Commercial Service</a>
        </div>
      </div>

    </div>
  </section>

  <!-- Pricing Info -->
  <section class="pricing-info">
    <div class="container">
      <div class="pricing-box">
        <h2>Honest, Upfront Pricing</h2>
        <p>We believe in transparent pricing. Here's how it works:</p>
        <div class="pricing-grid">
          <div class="pricing-item">
            <h4>Diagnostic Fee</h4>
            <p class="price">$89</p>
            <p>We come to your home, diagnose the problem, and give you an exact quote. This fee is waived if you proceed with the repair.</p>
          </div>
          <div class="pricing-item">
            <h4>Labor</h4>
            <p class="price">$180+</p>
            <p>Most repairs are completed in 1-2 hours. You'll never be charged more than quoted.</p>
          </div>
          <div class="pricing-item">
            <h4>Parts</h4>
            <p class="price">OEM Quality</p>
            <p>We source quality replacement parts at competitive prices. No markups, no surprises.</p>
          </div>
          <div class="pricing-item">
            <h4>Warranty</h4>
            <p class="price">30 Days</p>
            <p>All parts and labor are covered for 30 days. If it breaks again, we fix it free.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-section">
    <div class="container">
      <div class="cta-box">
        <h2>Have an Appliance That Needs Repair?</h2>
        <p>Contact us today. We'll diagnose the problem and give you an upfront quote — no obligation.</p>
        <div class="cta-btns">
          <a href="tel:+15033893142" class="btn btn-accent">📞 (503) 389-3142</a>
          <a href="/contact" class="btn btn-outline-white">Get a Quote</a>
        </div>
      </div>
    </div>
  </section>

</Layout>

<style>
  .page-header {
    background: var(--primary);
    color: var(--white);
    padding: 4rem 0;
    text-align: center;
  }

  .page-header h1 {
    font-size: 2.75rem;
    font-weight: 800;
    margin-bottom: 0.75rem;
  }

  .page-header p {
    font-size: 1.15rem;
    color: #bfdbfe;
    max-width: 600px;
    margin: 0 auto;
  }

  .services-list {
    padding: 4rem 0;
  }

  .service-row {
    display: grid;
    grid-template-columns: 1fr 1.5fr;
    gap: 4rem;
    align-items: center;
    padding: 3rem 0;
    border-bottom: 1px solid var(--gray-300);
  }

  .service-row:nth-child(even) {
    direction: rtl;
  }

  .service-row:nth-child(even) > * {
    direction: ltr;
  }

  .service-row-image {
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 12px 32px rgba(0,0,0,0.1);
  }

  .service-row-image img {
    width: 100%;
    height: 350px;
    object-fit: cover;
    display: block;
  }

  .service-badge {
    display: inline-block;
    background: #dcfce7;
    color: #15803d;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0.25rem 0.75rem;
    border-radius: 999px;
    margin-bottom: 0.75rem;
  }

  .commercial-badge {
    background: #fef3c7;
    color: #92400e;
  }

  .service-row-content h2 {
    font-size: 2rem;
    font-weight: 700;
    margin-bottom: 1rem;
  }

  .service-row-content > p {
    color: var(--gray-500);
    font-size: 1.05rem;
    margin-bottom: 1.5rem;
    line-height: 1.7;
  }

  .service-details {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    margin-bottom: 1.5rem;
  }

  .detail-group h4 {
    font-size: 0.875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--primary);
    margin-bottom: 0.75rem;
  }

  .detail-group ul {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .detail-group li {
    color: var(--gray-700);
    font-size: 0.95rem;
    padding-left: 1rem;
    position: relative;
  }

  .detail-group li::before {
    content: "•";
    position: absolute;
    left: 0;
    color: var(--primary);
  }

  /* Pricing */
  .pricing-info {
    background: var(--gray-100);
    padding: 4rem 0;
  }

  .pricing-box {
    text-align: center;
  }

  .pricing-box h2 {
    font-size: 2rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
  }

  .pricing-box > p {
    color: var(--gray-500);
    margin-bottom: 2.5rem;
  }

  .pricing-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
    text-align: center;
  }

  .pricing-item {
    background: var(--white);
    padding: 1.5rem;
    border-radius: 10px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.06);
    text-align: center;
  }

  .pricing-item h4 {
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
  }

  .pricing-item .price {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--primary);
    margin-bottom: 0.75rem;
  }

  .pricing-item p:last-child {
    color: var(--gray-500);
    font-size: 0.875rem;
    line-height: 1.5;
  }

  /* CTA */
  .cta-section {
    padding: 5rem 0;
  }

  .cta-box {
    background: var(--dark);
    color: var(--white);
    text-align: center;
    padding: 4rem;
    border-radius: 16px;
  }

  .cta-box h2 {
    font-size: 2.25rem;
    font-weight: 700;
    margin-bottom: 1rem;
  }

  .cta-box p {
    color: var(--gray-300);
    font-size: 1.1rem;
    margin-bottom: 2rem;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }

  .cta-btns {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .btn {
    display: inline-block;
    padding: 0.875rem 1.75rem;
    border-radius: var(--radius);
    font-weight: 600;
    font-size: 1rem;
    transition: all 0.2s;
    cursor: pointer;
  }

  .btn-primary {
    background: var(--primary);
    color: var(--white);
  }

  .btn-primary:hover {
    background: var(--primary-light);
  }

  .btn-accent {
    background: var(--accent);
    color: var(--dark);
  }

  .btn-accent:hover {
    background: var(--accent-dark);
  }

  .btn-outline-white {
    background: transparent;
    color: var(--white);
    border: 2px solid var(--white);
  }

  .btn-outline-white:hover {
    background: var(--white);
    color: var(--dark);
  }

  @media (max-width: 900px) {
    .service-row {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .service-row:nth-child(even) {
      direction: ltr;
    }

    .service-row-image img {
      height: 250px;
    }

    .service-details {
      grid-template-columns: 1fr;
    }

    .pricing-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .page-header h1 {
      font-size: 2rem;
    }

    .service-row-content {
      text-align: center;
    }

    .service-row-content h2 {
      text-align: center;
    }

    .service-row-content > p {
      text-align: center;
    }

    .detail-group {
      text-align: center;
    }

    .detail-group ul {
      align-items: center;
    }

    .pricing-box {
      text-align: center;
    }

    .pricing-grid {
      grid-template-columns: 1fr;
      text-align: center;
    }

    .cta-btns {
      flex-direction: column;
      align-items: center;
    }
  }
</style>
